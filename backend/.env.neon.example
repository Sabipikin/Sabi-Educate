# Neon Postgres example environment variables
# Replace the values with your Neon connection string and optional Supabase keys.
DATABASE_URL=postgresql://<username>:<password>@<host>:5432/<database>?sslmode=require
DEBUG=False

# Optional Supabase configuration (if you also want Supabase features)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-key
